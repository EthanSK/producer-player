{
  "name": "producer-player",
  "version": "0.2.0",
  "private": true,
  "description": "Producer Player desktop app for producers managing album tracks, exports, and ordering.",
  "author": "EthanSK",
  "license": "MIT",
  "homepage": "https://ethansk.github.io/producer-player/",
  "repository": {
    "type": "git",
    "url": "https://github.com/EthanSK/producer-player.git"
  },
  "main": "apps/electron/dist/main.cjs",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run build:packages && concurrently -k -n RENDERER,ELECTRON -c cyan,magenta \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "npm run dev -w @producer-player/renderer",
    "dev:electron": "npm run dev -w @producer-player/electron",
    "build:packages": "npm run build -w @producer-player/contracts && npm run build -w @producer-player/domain",
    "build": "npm run build:packages && npm run build -w @producer-player/renderer && npm run build -w @producer-player/electron",
    "build:mac": "node ./scripts/build-mac.mjs zip",
    "build:mac:dir": "node ./scripts/build-mac.mjs dir",
    "build:mac:mas-dev": "node ./scripts/build-mac.mjs mas-dev",
    "build:mac:mas": "node ./scripts/build-mac.mjs mas",
    "build:mac:app-store": "node ./scripts/build-mac.mjs mas",
    "typecheck": "npm run typecheck -w @producer-player/contracts && npm run typecheck -w @producer-player/domain && npm run typecheck -w @producer-player/renderer && npm run typecheck -w @producer-player/electron && npm run typecheck -w @producer-player/e2e",
    "e2e": "npm run build && npm run test -w @producer-player/e2e",
    "e2e:ci": "npm run build && npm run ci -w @producer-player/e2e",
    "clean": "rimraf \"apps/*/dist\" \"packages/*/dist\"",
    "release:desktop:mac": "npm run build:mac",
    "release:desktop:linux": "npm run build && electron-builder --linux zip --publish never",
    "release:desktop:win": "npm run build && electron-builder --win zip --publish never",
    "icon:build": "./scripts/generate-app-icon.sh",
    "plan:audit": "python3 scripts/plan_verbatim_audit.py --session \"$SESSION_JSONL\" --plan PLAN.md",
    "plan:audit:append": "python3 scripts/plan_verbatim_audit.py --session \"$SESSION_JSONL\" --plan PLAN.md --append-missing"
  },
  "build": {
    "appId": "com.ethansk.producerplayer",
    "productName": "Producer Player",
    "electronVersion": "40.6.1",
    "asar": true,
    "asarUnpack": [
      "apps/electron/dist/bin/**"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "apps/electron/dist/**/*",
      "apps/renderer/dist/**/*",
      "package.json"
    ],
    "afterSign": "scripts/notarize.js",
    "mac": {
      "target": [
        "zip"
      ],
      "category": "public.app-category.music",
      "icon": "assets/icon/ProducerPlayer.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "artifactName": "Producer-Player-${version}-mac-${arch}.${ext}"
    },
    "mas": {
      "type": "distribution",
      "entitlements": "build/entitlements.mas.plist",
      "entitlementsInherit": "build/entitlements.mas.inherit.plist",
      "provisioningProfile": "${env.PRODUCER_PLAYER_PROVISIONING_PROFILE}",
      "gatekeeperAssess": false,
      "artifactName": "Producer-Player-${version}-mas-${arch}.${ext}"
    },
    "masDev": {
      "type": "development",
      "entitlements": "build/entitlements.mas.plist",
      "entitlementsInherit": "build/entitlements.mas.inherit.plist",
      "provisioningProfile": "${env.PRODUCER_PLAYER_PROVISIONING_PROFILE}",
      "gatekeeperAssess": false,
      "artifactName": "Producer-Player-${version}-mas-dev-${arch}.${ext}"
    },
    "linux": {
      "target": [
        "zip"
      ],
      "artifactName": "Producer-Player-${version}-linux-${arch}.${ext}"
    },
    "win": {
      "target": [
        "zip"
      ],
      "artifactName": "Producer-Player-${version}-win-${arch}.${ext}"
    }
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron-builder": "^26.0.12",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.2",
    "wait-on": "^9.0.1"
  }
}
